SERVER_PORT=8081
LOG_LEVEL=info
MYSQL_DSN=root:change-me@tcp(127.0.0.1:3306)/workflow?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MAX_IDLE_CONNS=5
MYSQL_CONN_MAX_LIFETIME=30m
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
# MAIN(8080): stub | jst（jst 需 openweb 凭证，与 Bridge 共用 ERP_REMOTE_*）
ERP_SYNC_SOURCE_MODE=stub
ERP_STUB_FILE=config/erp-products.json
ERP_SYNC_ENABLED=false
ERP_BRIDGE_BASE_URL=http://127.0.0.1:8081
ERP_REMOTE_MODE=local
ERP_REMOTE_BASE_URL=https://openapi.jushuitan.com
ERP_REMOTE_UPSERT_PATH=/open/webapi/itemapi/itemsku/itemskubatchupload
ERP_REMOTE_ITEM_STYLE_UPDATE_PATH=/open/webapi/itemapi/itemskuim/itemupload
ERP_REMOTE_SHELVE_BATCH_PATH=/open/webapi/wmsapi/openshelve/skubatchshelve
ERP_REMOTE_UNSHELVE_BATCH_PATH=/open/webapi/wmsapi/openoffshelve/skubatchoffshelve
ERP_REMOTE_VIRTUAL_QTY_PATH=/open/webapi/itemapi/iteminventory/batchupdatewmsvirtualqtys
# Jushuitan 普通商品资料查询（按 SKU）；若与贵司网关路径不一致请覆盖
ERP_REMOTE_SKU_QUERY_PATH=/open/sku/query
ERP_SHORT_NAME_RULE_FILE=config/erp_short_name_rules.json
ERP_REMOTE_TIMEOUT=15s
ERP_REMOTE_RETRY_MAX=2
ERP_REMOTE_RETRY_BACKOFF=600ms
ERP_REMOTE_AUTH_MODE=openweb
ERP_REMOTE_AUTH_HEADER_TOKEN=
ERP_REMOTE_APP_KEY=
ERP_REMOTE_APP_SECRET=
ERP_REMOTE_ACCESS_TOKEN=
ERP_REMOTE_OPENWEB_CHARSET=utf-8
ERP_REMOTE_OPENWEB_VERSION=2
ERP_REMOTE_HEADER_APP_KEY=X-App-Key
ERP_REMOTE_HEADER_ACCESS_TOKEN=X-Access-Token
ERP_REMOTE_HEADER_TIMESTAMP=X-Timestamp
ERP_REMOTE_HEADER_NONCE=X-Nonce
ERP_REMOTE_HEADER_SIGNATURE=X-Signature
ERP_REMOTE_SIGNATURE_INCLUDE_BODY_HASH=true
ERP_REMOTE_FALLBACK_LOCAL_ON_ERROR=true
