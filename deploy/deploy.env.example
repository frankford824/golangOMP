DEPLOY_HOST=223.4.249.11
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_BASE_DIR=/root/ecommerce_ai
DEPLOY_AUTH_MODE=key

# Optional. Prefer SSH key: run deploy/setup-ssh-key.ps1 (Windows IDE / PowerShell)
# or deploy/setup-ssh-key.sh (bash) once, then deploy without password.
# Password mode is compatibility-only and must be enabled explicitly:
# DEPLOY_AUTH_MODE=password
# DEPLOY_PASSWORD=replace-me-locally

# Optional settings.
DEPLOY_APP_NAME=ecommerce-ai
DEPLOY_KEEP_RELEASES=5
DEPLOY_MAIN_PORT=8080
DEPLOY_BRIDGE_BASE_URL=http://127.0.0.1:8081

# Optional local files to upload during remote deploy.
# DEPLOY_RUNTIME_ENV_FILE=deploy/main.env
# DEPLOY_BRIDGE_ENV_FILE=deploy/bridge.env
