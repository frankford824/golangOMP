SERVER_PORT=8080
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/workflow?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
ERP_SYNC_ENABLED=true
ERP_SYNC_INTERVAL=5m
ERP_SYNC_SOURCE_MODE=stub
ERP_SYNC_STUB_FILE=config/erp_products_stub.json
ERP_SYNC_TIMEOUT=30s
ERP_BRIDGE_BASE_URL=http://127.0.0.1:8081
ERP_BRIDGE_TIMEOUT=15s
UPLOAD_SERVICE_ENABLED=true
UPLOAD_SERVICE_BASE_URL=http://100.111.214.38:8089
# Browser-facing multipart upload base.
# Recommended: "/" so MAIN returns same-origin "/upload/*" URLs.
# - deployed dist can call them directly through nginx
# - local Vite can proxy "/upload" in dev-server config
UPLOAD_SERVICE_BROWSER_MULTIPART_BASE_URL=/
# Optional browser-facing direct download base.
# Example: https://<bucket>.<region>.aliyuncs.com
# When set, MAIN builds browser-direct download_url from storage_key on this base.
UPLOAD_SERVICE_BROWSER_DOWNLOAD_BASE_URL=
UPLOAD_SERVICE_TIMEOUT=15s
UPLOAD_SERVICE_INTERNAL_TOKEN=
# Backward-compatible legacy alias. Prefer UPLOAD_SERVICE_INTERNAL_TOKEN.
UPLOAD_SERVICE_AUTH_TOKEN=
UPLOAD_STORAGE_PROVIDER=oss
LOG_LEVEL=info
